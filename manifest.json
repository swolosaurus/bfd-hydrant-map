{
  "name": "BFD Hydrant Map",
  "short_name": "BFD Hydrants",
  "description": "Boston Fire Department — nearest hydrants to any incident address",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#111111",
  "theme_color": "#C8102E",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Use My Location",
      "short_name": "GPS",
      "description": "Show hydrants at current location",
      "url": "./?gps=1"
    }
  ],
  "share_target": {
    "action": "./",
    "method": "GET",
    "params": {
      "title": "title",
      "text":  "address",
      "url":   "url"
    }
  }
}
